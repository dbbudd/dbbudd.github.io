# ═══════════════════════════════════════════════════════════════
# Geometry Playground — .gitignore
# ═══════════════════════════════════════════════════════════════

# ── OS cruft ──────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── Editor / IDE ─────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace
.project
.settings/

# ── Node / npm (in case we ever add tooling) ─────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
package-lock.json
yarn.lock

# ── Python (in case we ever add tooling) ─────────────────────
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.env

# ── Secrets / environment ────────────────────────────────────
.env
.env.local
.env.*.local
*.key
*.pem
secrets.json

# ── Build artifacts ──────────────────────────────────────────
dist/
build/
out/
.cache/
.parcel-cache/
.next/
.nuxt/

# ── Logs ─────────────────────────────────────────────────────
*.log
logs/

# ── Claude / AI assistant notes (internal, not for public) ──
CLAUDE.md
course-ui/CLAUDE.md
.claude/
.cursor/

# ── Curriculum scratchpads (spoilers / internal) ─────────────
05_solutions.md
*_solutions.md
scratch/
notes/

# ── Temp files ───────────────────────────────────────────────
*.tmp
*.bak
*.orig
*.rej
